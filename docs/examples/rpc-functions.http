###
# University Assist API Examples - RPC Functions
# 
# Base URL: https://zfiexgjcuojodmnsinsz.supabase.co/rest/v1/rpc
# 
# Replace {SUPABASE_ANON_KEY} with your actual key  
# Replace {JWT_TOKEN} with valid JWT for authenticated requests
###

### Get admin dashboard statistics (requires admin authentication)
POST https://zfiexgjcuojodmnsinsz.supabase.co/rest/v1/rpc/get_admin_dashboard_stats
apikey: {SUPABASE_ANON_KEY}
Authorization: Bearer {JWT_TOKEN}
Content-Type: application/json

{}

### Get secure profile data (requires authentication)
POST https://zfiexgjcuojodmnsinsz.supabase.co/rest/v1/rpc/get_safe_profile_data
apikey: {SUPABASE_ANON_KEY}
Authorization: Bearer {JWT_TOKEN}
Content-Type: application/json

{
  "profile_uuid": "{user-profile-uuid-here}"
}

### Check profile access rights (requires authentication)
POST https://zfiexgjcuojodmnsinsz.supabase.co/rest/v1/rpc/check_profile_access_rights
apikey: {SUPABASE_ANON_KEY}
Authorization: Bearer {JWT_TOKEN}
Content-Type: application/json

{
  "profile_uuid": "{user-profile-uuid-here}"
}

### Secure profile update (requires authentication)
POST https://zfiexgjcuojodmnsinsz.supabase.co/rest/v1/rpc/ultra_secure_profile_update
apikey: {SUPABASE_ANON_KEY}
Authorization: Bearer {JWT_TOKEN}
Content-Type: application/json

{
  "target_profile_id": "{user-profile-uuid-here}",
  "update_data": {
    "full_name": "Updated Name",
    "current_institution": "New University"
  }
}

### Check QA users setup (requires authentication)
POST https://zfiexgjcuojodmnsinsz.supabase.co/rest/v1/rpc/check_qa_users_setup
apikey: {SUPABASE_ANON_KEY}
Authorization: Bearer {JWT_TOKEN}
Content-Type: application/json

{}

### Get current application period for program (requires authentication)
POST https://zfiexgjcuojodmnsinsz.supabase.co/rest/v1/rpc/get_current_application_period
apikey: {SUPABASE_ANON_KEY}
Authorization: Bearer {JWT_TOKEN}
Content-Type: application/json

{
  "program_uuid": "{program-uuid-here}"
}

